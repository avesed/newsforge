# =============================================================================
# NewsForge Environment Configuration
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://newsforge:newsforge@localhost:5432/newsforge
POSTGRES_USER=newsforge
POSTGRES_PASSWORD=newsforge
POSTGRES_DB=newsforge

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
JWT_SECRET_KEY=change-me-to-64-char-hex-string-in-production-abcdef1234567890
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- LLM (at least one required) ---
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Content Fetching (optional) ---
# TAVILY_API_KEY=
# PLAYWRIGHT_SERVICE_URL=http://localhost:8931

# --- RSSHub (optional) ---
# RSSHUB_URL=http://localhost:1200
# RSSHUB_ACCESS_KEY=

# --- News Sources API Keys (optional) ---
# FINNHUB_API_KEY=
# NEWSAPI_KEY=

# --- StockPulse (per-symbol fan-out aggregator) ---
# When configured, NewsForge polls StockPulse for news of every symbol in
# the watched_symbols table. Consumers (e.g. WebStock) post their
# watchlists to /api/internal/watched-symbols/sync and NewsForge's
# scheduler polls StockPulse on hot/warm/cold tiers.
# STOCKPULSE_URL=http://stockpulse-app:80
# STOCKPULSE_API_KEY=

# --- App ---
DEBUG=true
LOG_LEVEL=INFO
FIRST_ADMIN_EMAIL=admin@newsforge.local
